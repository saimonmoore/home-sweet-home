{{- $needsTaskwarrior := false -}}
{{- if hasKey . "needs_taskwarrior" }}{{- $needsTaskwarrior = .needs_taskwarrior }}{{- end }}
{{- if and $needsTaskwarrior (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v apt-get >/dev/null 2>&1; then
	exit 0
fi

# Ubuntu 24.04 ships taskwarrior 2.x as `taskwarrior`. The task3 package
# line would go here once the distro catches up; for now install v2.
if dpkg -s taskwarrior >/dev/null 2>&1; then
	exit 0
fi

export DEBIAN_FRONTEND=noninteractive

if [[ "$(id -u)" -eq 0 ]]; then
	apt-get update
	exec apt-get install -y --no-install-recommends taskwarrior
fi

if command -v sudo >/dev/null 2>&1; then
	sudo apt-get update
	exec sudo apt-get install -y --no-install-recommends taskwarrior
fi

echo "Error: taskwarrior is not installed and sudo is unavailable." >&2
exit 1
{{- end }}
