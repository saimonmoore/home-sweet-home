{{- if and (eq .chezmoi.os "darwin") (not .develop) -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v brew >/dev/null 2>&1; then
	echo "Error: Homebrew is required on the macOS host before running chezmoi." >&2
	exit 1
fi

for brewfile in \
	{{ joinPath .chezmoi.sourceDir ".." "bootstrap" "host" "Brewfile.personal" | quote }} \
	{{ joinPath .chezmoi.sourceDir "bootstrap" "host" "Brewfile.personal" | quote }}; do
	if [[ -f "$brewfile" ]]; then
		exec brew bundle --file "$brewfile"
	fi
done

echo "Error: could not locate bootstrap/host/Brewfile.personal from chezmoi source path {{ .chezmoi.sourceDir }}." >&2
exit 1
{{- end }}
