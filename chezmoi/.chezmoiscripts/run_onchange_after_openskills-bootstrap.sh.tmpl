#!/usr/bin/env bash
# openskills manifest hash: {{ include "dot_agent/openskills-manifest.txt" | sha256sum }}
#
# Reconcile ~/.agent/skills with the committed openskills manifest.
#
#   1. Read the skill names from ~/.agent/openskills-manifest.txt
#   2. For each, look up its source in the committed
#      ~/.agent/skills/<name>/.openskills.json, dedupe, and
#      `npx openskills install <source> --universal`
#   3. Prune any skill dir on disk whose name is not in the manifest
#   4. Refresh ~/.agent/AGENTS.md via `npx openskills sync`
#   5. Refresh ~/.agents/skills -> ~/.agent/skills for Codex compatibility

set -uo pipefail

SKILLS_ROOT="$HOME/.agent/skills"
MANIFEST="$HOME/.agent/openskills-manifest.txt"
AGENTS_MD="$HOME/.agent/AGENTS.md"
CODEX_AGENTS_DIR="$HOME/.agents"
CODEX_SKILLS_LINK="$CODEX_AGENTS_DIR/skills"

# chezmoi hooks run in a bash subshell that inherits whatever PATH the
# invoking shell had. If the caller hasn't activated mise (which is the
# normal case right after `mise install` in a pre-existing shell), its
# shims aren't on PATH and npx is invisible even though node is
# installed. Prepend the shims dir ourselves so this hook is robust
# regardless of caller state.
if [[ -d "$HOME/.local/share/mise/shims" ]]; then
	export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

if ! command -v npx >/dev/null 2>&1; then
	echo "Error: npx missing. On the host install node via the Brewfile; in the VM run 'mise install' and ensure ~/.local/share/mise/shims is reachable." >&2
	exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
	echo "Error: jq missing." >&2
	exit 1
fi

# openskills uses node's cpSync to install skills over an existing target.
# Node can't overwrite read-only files, so a previous install that copied
# a source repo's .git directory (mode 444 pack files) blocks the next
# install with EACCES. Drop any stray .git dirs and flip everything to
# writable before the install loop — openskills will recreate whatever
# it needs from a clean base.
if [[ -d "$SKILLS_ROOT" ]]; then
	chmod -R u+w "$SKILLS_ROOT" 2>/dev/null || true
	find "$SKILLS_ROOT" -mindepth 2 -type d -name '.git' \
		-exec rm -rf {} + 2>/dev/null || true
fi

if [[ ! -f "$MANIFEST" ]]; then
	echo "No openskills manifest at $MANIFEST; skipping agent skills sync."
	exit 0
fi

mapfile -t desired < <(
	sed -E 's/#.*//' "$MANIFEST" \
		| awk 'NF > 0 { print $1 }' \
		| sort -u
)

if [[ ${#desired[@]} -eq 0 ]]; then
	echo "openskills manifest is empty; skipping."
	exit 0
fi

# Collect unique sources from the committed .openskills.json files.
declare -A sources=()
for name in "${desired[@]}"; do
	meta="$SKILLS_ROOT/$name/.openskills.json"
	if [[ ! -f "$meta" ]]; then
		echo "Warning: no .openskills.json for '$name' at $meta (skipping install lookup)." >&2
		continue
	fi
	src=$(jq -r '.source // empty' "$meta")
	if [[ -z "$src" ]]; then
		echo "Warning: no 'source' in $meta" >&2
		continue
	fi
	sources["$src"]=1
done

if [[ ${#sources[@]} -eq 0 ]]; then
	echo "No installable sources found; skipping openskills install."
	exit 0
fi

failed=0
for src in "${!sources[@]}"; do
	echo "==> openskills install $src"
	if ! npx --yes openskills install "$src" --universal --yes; then
		failed=$((failed+1))
	fi
done

# Prune: any skill dir not in the manifest gets removed.
if [[ -d "$SKILLS_ROOT" ]]; then
	mapfile -t installed < <(
		find "$SKILLS_ROOT" -mindepth 1 -maxdepth 1 -type d \
			-exec basename {} \; 2>/dev/null \
			| sort -u
	)

	mapfile -t to_remove < <(
		comm -23 \
			<(printf '%s\n' "${installed[@]}") \
			<(printf '%s\n' "${desired[@]}")
	)

	for name in "${to_remove[@]}"; do
		echo "==> openskills remove $name (not in manifest)"
		npx --yes openskills remove "$name" || true
	done
fi

echo "==> openskills sync -o $AGENTS_MD"
npx --yes openskills sync -y -o "$AGENTS_MD" || true

mkdir -p "$CODEX_AGENTS_DIR"
ln -sfn "$SKILLS_ROOT" "$CODEX_SKILLS_LINK"

if (( failed > 0 )); then
	echo "$failed source(s) failed to install; re-run this hook after fixing." >&2
	exit 1
fi
