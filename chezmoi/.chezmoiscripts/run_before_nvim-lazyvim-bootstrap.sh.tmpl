{{- if .develop -}}
#!/usr/bin/env bash
set -euo pipefail

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"

if [[ -e "$config_dir" ]] && [[ -n "$(ls -A "$config_dir" 2>/dev/null)" ]]; then
	exit 0
fi

if ! command -v git >/dev/null 2>&1; then
	echo "Error: git is required to bootstrap LazyVim." >&2
	exit 1
fi

mkdir -p "$(dirname "$config_dir")"
# Bypass any `url."git@github.com:".insteadOf = https://github.com/` rewrite
# from the VM gitconfig so this bootstrap works on a brand-new VM before
# the user has registered ~/.ssh/id_ed25519.pub with GitHub.
git -c 'url.https://github.com/.insteadOf=' \
    clone --depth 1 https://github.com/LazyVim/starter "$config_dir"
rm -rf "$config_dir/.git"

echo "LazyVim starter cloned into $config_dir."
echo "Open nvim once to let lazy.nvim install plugins and treesitter parsers."
{{- end }}
