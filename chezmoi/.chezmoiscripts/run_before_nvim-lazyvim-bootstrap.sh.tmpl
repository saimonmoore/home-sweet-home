{{- if .develop -}}
#!/usr/bin/env bash
set -euo pipefail

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"

if [[ -e "$config_dir" ]] && [[ -n "$(ls -A "$config_dir" 2>/dev/null)" ]]; then
	exit 0
fi

if ! command -v git >/dev/null 2>&1; then
	echo "Error: git is required to bootstrap LazyVim." >&2
	exit 1
fi

mkdir -p "$(dirname "$config_dir")"
# Isolate from whatever ~/.gitconfig / /etc/gitconfig may exist — in
# particular, `url."git@github.com:".insteadOf = https://github.com/`
# rewrites would force SSH auth before the user has registered their
# key with GitHub. Also protects against our previous bug where a
# `-c url.https://github.com/.insteadOf=` (empty value) caused git to
# double-prepend "https://github.com/" to every URL it saw.
GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null \
    git clone --depth 1 https://github.com/LazyVim/starter "$config_dir"
rm -rf "$config_dir/.git"

echo "LazyVim starter cloned into $config_dir."
echo "Open nvim once to let lazy.nvim install plugins and treesitter parsers."
{{- end }}
