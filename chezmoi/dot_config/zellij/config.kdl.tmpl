// ~/.config/zellij/config.kdl

{{- $needsTaskwarrior := false -}}
{{- if hasKey . "needs_taskwarrior" }}{{- $needsTaskwarrior = .needs_taskwarrior }}{{- end }}

theme "catppuccin-mocha"

simplified_ui true
pane_frames false
default_mode "locked"
copy_on_select true
scrollback_editor "nvim"
mouse_mode true
show_startup_tips false
web_server false
web_sharing "off"

keybinds {
    unbind "Ctrl g"

    normal {
        bind "Alt l" { SwitchToMode "Locked"; }

        // Floating tools
        bind "Alt f" {
            Run "zsh" "-l" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt g" {
            Run "lazygit" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt e" {
            Run "zsh" "-lc" "exec yazi \"$PWD\"" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt r" {
            Run "scooter" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- if $needsTaskwarrior }}
        bind "Alt w" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",task-popup" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- end }}
        bind "Alt ?" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",cheatsheet" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }

        // Pane actions
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        // Alt l handled above (mode switch) — move-focus-right in locked only
        bind "Alt v" { NewPane "Right"; }
        bind "Alt o" { TogglePaneEmbedOrFloating; }
        bind "Alt z" { ToggleFocusFullscreen; }

        // Tab actions
        bind "Alt t" { NewTab; }
        bind "Alt m" { SwitchToMode "RenameTab"; }
        bind "Alt n" { GoToNextTab; }
        bind "Alt p" { GoToPreviousTab; }
        bind "Alt q" { CloseTab; }
        bind "Alt d" { Detach; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }

    locked {
        bind "Alt a" { SwitchToMode "Normal"; }

        // Floating tools
        bind "Alt f" {
            Run "zsh" "-l" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt g" {
            Run "lazygit" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt e" {
            Run "zsh" "-lc" "exec yazi \"$PWD\"" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt r" {
            Run "scooter" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- if $needsTaskwarrior }}
        bind "Alt w" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",task-popup" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- end }}
        bind "Alt ?" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",cheatsheet" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }

        // Pane actions
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt l" { MoveFocus "Right"; }
        bind "Alt v" { NewPane "Right"; }
        bind "Alt o" { TogglePaneEmbedOrFloating; }
        bind "Alt z" { ToggleFocusFullscreen; }

        // Tab actions
        bind "Alt t" { NewTab; }
        bind "Alt m" { SwitchToMode "RenameTab"; }
        bind "Alt n" { GoToNextTab; }
        bind "Alt p" { GoToPreviousTab; }
        bind "Alt q" { CloseTab; }

        // Session actions
        bind "Alt d" { Detach; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }

    renametab {
        bind "Ctrl c" { SwitchToMode "Locked"; }
        bind "Enter" { SwitchToMode "Locked"; }
        bind "Esc" { UndoRenameTab; SwitchToMode "Locked"; }
    }

    shared_except "locked" {
        bind "Alt a" { SwitchToMode "Locked"; }
    }
}
