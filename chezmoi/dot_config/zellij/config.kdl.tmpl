// ~/.config/zellij/config.kdl

{{- $needsTaskwarrior := false -}}
{{- if hasKey . "needs_taskwarrior" }}{{- $needsTaskwarrior = .needs_taskwarrior }}{{- end }}

theme "catppuccin-mocha"

simplified_ui true
pane_frames false
default_mode "locked"
copy_on_select true
scrollback_editor "nvim"
mouse_mode true
show_startup_tips false
web_server false
web_sharing "off"

keybinds {
    unbind "Ctrl g"

    normal {
        bind "Alt l" { SwitchToMode "Locked"; }

        // Floating tools
        bind "Alt F" {
            Run "zsh" "-l" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt G" {
            Run "lazygit" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt E" {
            Run "zsh" "-lc" "exec yazi \"$PWD\"" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt R" {
            Run "scooter" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- if $needsTaskwarrior }}
        bind "Alt W" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",task-popup" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- end }}
        bind "Alt ?" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",cheatsheet" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }

        // Pane actions
        bind "Alt H" { MoveFocus "Left"; }
        bind "Alt J" { MoveFocus "Down"; }
        bind "Alt K" { MoveFocus "Up"; }
        bind "Alt L" { MoveFocus "Right"; }
        bind "Alt V" { NewPane "Right"; }
        bind "Alt O" { TogglePaneEmbedOrFloating; }
        bind "Alt Z" { ToggleFocusFullscreen; }

        // Tab actions
        bind "Alt T" { NewTab; }
        bind "Alt M" { SwitchToMode "RenameTab"; }
        bind "Alt N" { GoToNextTab; }
        bind "Alt P" { GoToPreviousTab; }
        bind "Alt Q" { CloseTab; }
        bind "Alt D" { Detach; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }

    locked {
        bind "Alt a" { SwitchToMode "Normal"; }

        // Floating tools
        bind "Alt F" {
            Run "zsh" "-l" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt G" {
            Run "lazygit" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt E" {
            Run "zsh" "-lc" "exec yazi \"$PWD\"" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
        bind "Alt R" {
            Run "scooter" {
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- if $needsTaskwarrior }}
        bind "Alt W" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",task-popup" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }
{{- end }}
        bind "Alt ?" {
            Run {{ joinPath .chezmoi.homeDir ".local" "bin" ",cheatsheet" | quote }} {
                cwd "."
                floating true
                x "7%"
                y "7%"
                width "86%"
                height "86%"
                close_on_exit true
            }
        }

        // Pane actions
        bind "Alt H" { MoveFocus "Left"; }
        bind "Alt J" { MoveFocus "Down"; }
        bind "Alt K" { MoveFocus "Up"; }
        bind "Alt L" { MoveFocus "Right"; }
        bind "Alt V" { NewPane "Right"; }
        bind "Alt O" { TogglePaneEmbedOrFloating; }
        bind "Alt Z" { ToggleFocusFullscreen; }

        // Tab actions
        bind "Alt T" { NewTab; }
        bind "Alt M" { SwitchToMode "RenameTab"; }
        bind "Alt N" { GoToNextTab; }
        bind "Alt P" { GoToPreviousTab; }
        bind "Alt Q" { CloseTab; }

        // Session actions
        bind "Alt D" { Detach; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }

    renametab {
        bind "Ctrl c" { SwitchToMode "Locked"; }
        bind "Enter" { SwitchToMode "Locked"; }
        bind "Esc" { UndoRenameTab; SwitchToMode "Locked"; }
    }

    shared_except "locked" {
        bind "Alt a" { SwitchToMode "Locked"; }
    }
}
