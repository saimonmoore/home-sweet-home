// ~/.config/zellij/layouts/dev-agentic.kdl

layout {
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }

    pane split_direction="vertical" {
        pane name="nvim" command="nvim" size="70%" focus=true
        pane name="opencode" command="opencode" size="30%"
    }
}
