# PATH additions live here (not in .zshrc / rc.d) so they're available
# in non-interactive login shells too — e.g. `zsh -lc ",agent"` from a
# zellij layout. Interactive shells inherit from this, and
# `typeset -U path PATH` in rc.d/05_homebrew.tmpl dedupes on reload.
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
export PATH="$HOME/.local/share/mise/shims:$PATH"

{{- if eq .chezmoi.os "linux" }}

# In the Linux dev VM we run rootless Docker. The daemon's socket
# lives under $XDG_RUNTIME_DIR (the user runtime dir), and is set up
# by the chezmoi run_once_after_vm-docker-rootless.sh hook (which
# runs `dockerd-rootless-setuptool.sh install`). Exporting DOCKER_HOST
# lets `docker` / `docker compose` find the daemon without any extra
# CLI flags.
export DOCKER_HOST="unix://${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/docker.sock"
{{- end }}
