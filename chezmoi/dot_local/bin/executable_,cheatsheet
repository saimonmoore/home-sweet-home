#!/usr/bin/env bash
set -euo pipefail

tmpfile="$(mktemp)"
trap 'rm -f "$tmpfile"' EXIT

cat >"$tmpfile" <<'EOF'
TOOLS CHEATSHEET

YAZI
  Launch:
    yazi

  Basics:
    h / l       go to parent / enter directory
    j / k       move
    g / G       top / bottom
    Space       select
    Enter       open
    q           quit

  Useful:
    .           toggle hidden files
    /           search in current list
    a           create file or directory
    d           cut
    y           copy
    p           paste
    r           rename
    x           open with chooser

  In this setup:
    files open in Neovim (LazyVim)
    hidden files are shown by default
    preview pane is enabled

LAZYGIT
  Launch:
    lazygit

  Basics:
    q           quit
    ?           keybinding help
    Tab         switch between side panel and main panel
    [ / ]       move between panels/tabs
    j / k       move
    Enter       open panel item / inspect
    Esc         back / cancel

  Common file actions:
    Space       stage or unstage selected file
    a           stage or unstage all files
    Enter       open hunk view for selected file
    c           commit staged changes
    P           push
    p           pull
    e           open selected file in Neovim

  Branches and commits:
    3           branches panel (or cycle with [ / ])
    n           new branch
    Space       checkout selected branch
    rebase / squash / fixup are available from commit views

ZELLIJ
  Launch:
    zellij

  Your setup starts locked.

  Mode toggle:
    Alt-a       unlock to Normal mode
    Alt-a       lock again from any unlocked mode

  Locked-mode quick actions:
    Alt-Shift-h/j/k/l move focus
    Alt-Shift-t       new tab
    Alt-Shift-m       rename current tab
    Alt-Shift-p       previous tab
    Alt-Shift-n       next tab
    Alt-1..9          go to tab 1..9
    Alt-Shift-f       floating zsh in current directory
    Alt-Shift-g       floating lazygit
    Alt-Shift-r       floating scooter
    Alt-Shift-e       floating yazi in current directory
    Alt-Shift-?       floating cheatsheet
    Alt-Shift-v       split pane right
    Alt-Shift-o       toggle focused pane floating/embedded
    Alt-Shift-z       zoom/unzoom focused pane
    Alt-Shift-q       close tab and panes
    Alt-Shift-d       detach session
    Ctrl-o            open session manager

  Notes:
    compact layout is enabled
    pane frames are enabled for focus visibility
    web server and web sharing are disabled

WEZTERM
  Tab shortcuts:
    Super-Shift-l     switch to first tab
    Super-Shift-d     switch to second tab
    Super-Shift-n     switch to next tab
    Super-Shift-p     switch to previous tab
    Super-Shift-c     create tab
    Super-Shift-r     rename current tab

  Notes:
    default wezterm multiplexer bindings are disabled
    persistent wezterm mux server is disabled
    wezterm starts with local and dev tabs

  Project flows:
    ,zdev       pick project with zoxide, open dev tab there
    ,zagent     pick project with zoxide, open dev-agentic tab there
    ,zlayout    pick project with zoxide, choose layout explicitly
    ,zj [name]  attach/create zellij session, default local

SCOOTER
  Launch:
    scooter

  What it is:
    interactive project-wide find/replace

  Basics:
    enter       run search from fields / apply replacements from results
    Tab         next field
    Shift-Tab   previous field
    j / k       move through matches
    Space       include or exclude current match
    a           toggle all matches
    v           multiselect mode
    e           open match in Neovim
    Ctrl-h      help
    Ctrl-r      reset back to search screen
    Ctrl-c      quit

  Useful toggles:
    Ctrl-t      include hidden files
    Alt-m       multiline search
    Alt-e       interpret escape sequences in replacement text
    Ctrl-l      toggle preview wrapping

  In this setup:
    e opens Neovim at the matching line and exits scooter
    syntax highlighting uses Catppuccin Mocha

NEOVIM / LAZYVIM
  Launch:
    nvim

  LazyVim ships its own keymap; press <Space> in normal mode
  to see the which-key popup with every leader binding.

  Frequently used leader bindings (default LazyVim):
    <Space>        open which-key menu
    <Space> ff     find files (Telescope)
    <Space> fg     live grep
    <Space> e      toggle file explorer (neo-tree)
    <Space> gg     open lazygit
    <Space> qq     quit all
    <Space> l      Lazy plugin manager
    <Space> cm     Mason (LSP / formatter installer)

  In this setup:
    Neovim is installed via mise on develop machines
    config lives in ~/.config/nvim (LazyVim starter)
    yazi, scooter, and lazygit open files with nvim

PROJECT TAB HELPERS
  ,zdev         zoxide picker -> new Zellij tab with dev layout
  ,zagent       zoxide picker -> new Zellij tab with dev-agentic layout
  ,zlayout dev  zoxide picker -> new tab with explicit layout

Tip:
  Most of these tools have built-in help on ? or a visible key legend at the bottom.
EOF

if [[ -t 1 ]] && command -v less >/dev/null 2>&1; then
	less -R "$tmpfile"
else
	cat "$tmpfile"
fi
