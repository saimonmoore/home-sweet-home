#!/usr/bin/env sh
# Read stdin and emit an OSC 52 escape sequence to stdout so the
# enclosing terminal (WezTerm on the macOS host) writes the content
# to the system clipboard.
#
# Writing to stdout (as opposed to /dev/tty) turns out to be the
# reliable path in every context we care about:
#
#   - Interactive shell: stdout is the pty, bytes reach the terminal.
#   - Pipeline (`echo x | osc52-copy`): stdout is inherited from the
#     shell, still a pty, still flows to the terminal.
#   - lima's `limactl shell dev -- …` one-shot: /dev/tty is often
#     unallocated or not routed to WezTerm, but stdout is piped
#     straight back to the host shell -> WezTerm.
#
# Works identically on the macOS host too, so a single script is
# right for both machines.

set -eu

# Limit to ~3 MB of base64 output; bigger is likely unintended and
# terminals often reject huge OSC 52 payloads anyway.
max_bytes=3000000

data="$(head -c "$max_bytes" | base64 | tr -d '\n')"
printf '\033]52;c;%s\007' "$data"
